      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "WITH\nfirst_views AS (\n    SELECT user_id, minMerge(first_view_date_state) AS cohort_date\n    FROM agg_user_first_view\n    GROUP BY user_id\n),\nactivity AS (\n    SELECT user_id, event_date\n    FROM agg_daily_user_activity\n    WHERE view_started > 0 OR view_finished > 0\n),\ncohort_sizes AS (\n    SELECT cohort_date, count() AS cohort_size\n    FROM first_views\n    GROUP BY cohort_date\n),\nretention AS (\n    SELECT\n        fv.cohort_date AS cohort_date,\n        dateDiff('day', fv.cohort_date, a.event_date) AS day_n,\n        uniqExact(fv.user_id) AS retained_users\n    FROM first_views fv\n    INNER JOIN activity a ON a.user_id = fv.user_id\n    WHERE dateDiff('day', fv.cohort_date, a.event_date) BETWEEN 0 AND 7\n    GROUP BY cohort_date, day_n\n)\nSELECT\n    cs.cohort_date,\n    round(100.0 * sumIf(retained_users, day_n = 0) / nullIf(cs.cohort_size, 0), 2) AS day_0,\n    round(100.0 * sumIf(retained_users, day_n = 1) / nullIf(cs.cohort_size, 0), 2) AS day_1,\n    round(100.0 * sumIf(retained_users, day_n = 2) / nullIf(cs.cohort_size, 0), 2) AS day_2,\n    round(100.0 * sumIf(retained_users, day_n = 3) / nullIf(cs.cohort_size, 0), 2) AS day_3,\n    round(100.0 * sumIf(retained_users, day_n = 4) / nullIf(cs.cohort_size, 0), 2) AS day_4,\n    round(100.0 * sumIf(retained_users, day_n = 5) / nullIf(cs.cohort_size, 0), 2) AS day_5,\n    round(100.0 * sumIf(retained_users, day_n = 6) / nullIf(cs.cohort_size, 0), 2) AS day_6,\n    round(100.0 * sumIf(retained_users, day_n = 7) / nullIf(cs.cohort_size, 0), 2) AS day_7\nFROM cohort_sizes cs\nLEFT JOIN retention r ON r.cohort_date = cs.cohort_date\nGROUP BY cs.cohort_date, cs.cohort_size\nORDER BY cs.cohort_date DESC\nLIMIT 90",
          "refId": "A"
        }
      ],
      "title": "Retention Cohort (Day 0-7)",
      "type": "table"
    },
